<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo.controllers.FormController"
            prefHeight="400.0" prefWidth="600.0">
            <padding>
                <Insets left="12" right="12" top="12" bottom="12"/>
            </padding>
            <Label text="Nombre"/>
            <TextField fx:id="txtCorreo" promptText="Ingresa un Correo"/>
            <Label text="Edad"/>
            <TextField fx:id="txtEdad" promptText="Ingresa tu edad"/>

            <Button text="validar" onAction="#onValidation"/>
            <Label fx:id="lblValidation" text=""/>




</VBox>
